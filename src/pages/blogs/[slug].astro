---
import { getCollection, type CollectionEntry } from "astro:content";
import MarkdownLayout from "../../layouts/MarkdownLayout.astro";

type BlogEntry = CollectionEntry<"blog">;

const toDate = (value: unknown): Date => {
  if (value instanceof Date) return value;
  const date = new Date(value as string);
  return Number.isNaN(date.getTime()) ? new Date(0) : date;
};

export async function getStaticPaths() {
  const entries: BlogEntry[] = await getCollection("blog", (entry: BlogEntry) => !entry.data.draft);
  return entries.map((entry: BlogEntry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: BlogEntry };
const { Content } = await entry.render();
---

<MarkdownLayout
  title={entry.data.title}
  description={entry.data.description}
  dateText={toDate(entry.data.date).toISOString().slice(0, 10)}
  tags={entry.data.tags}
  currentPath="/blogs/"
>
  <Content />
</MarkdownLayout>
