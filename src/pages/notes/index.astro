---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

type NoteEntry = CollectionEntry<"notes">;

const entries: NoteEntry[] = await getCollection("notes", (entry: NoteEntry) => !entry.data.draft);

const toDate = (value: unknown): Date => {
  if (value instanceof Date) return value;
  const date = new Date(value as string);
  return Number.isNaN(date.getTime()) ? new Date(0) : date;
};

const notes = entries
  .slice()
  .sort((a: NoteEntry, b: NoteEntry) => toDate(b.data.date).getTime() - toDate(a.data.date).getTime());
---

<BaseLayout title="笔记 | My Blog" description="开发笔记列表" currentPath="/notes/">
  <header class="page-header">
    <h1>开发笔记</h1>
    <p>共 {notes.length} 篇，按发布时间倒序展示。</p>
  </header>

  {notes.length === 0 ? (
    <p>暂无笔记内容。</p>
  ) : (
    <ul class="post-list">
      {
        notes.map((note: NoteEntry) => (
          <li>
            <a class="post-card" href={`${import.meta.env.BASE_URL}notes/${note.slug}/`}>
              <h2>{note.data.title}</h2>
              <div class="post-meta">
                <span>{toDate(note.data.date).toISOString().slice(0, 10)}</span>
                {note.data.tags.map((tag: string) => <span class="tag">{tag}</span>)}
              </div>
              {note.data.description && <p class="post-excerpt">{note.data.description}</p>}
            </a>
          </li>
        ))
      }
    </ul>
  )}
</BaseLayout>
