---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

type NoteEntry = CollectionEntry<"notes">;

const toDate = (value: unknown): Date => {
  if (value instanceof Date) return value;
  const date = new Date(value as string);
  return Number.isNaN(date.getTime()) ? new Date(0) : date;
};

const fmtDate = (value: unknown): string => toDate(value).toISOString().slice(0, 10);

const notes: NoteEntry[] = (await getCollection("notes", (entry: NoteEntry) => !entry.data.draft))
  .slice()
  .sort((a: NoteEntry, b: NoteEntry) => toDate(b.data.date).getTime() - toDate(a.data.date).getTime());

const tagSet = Array.from(new Set(notes.flatMap((note: NoteEntry) => note.data.tags))).sort((a, b) =>
  a.localeCompare(b),
);
---

<BaseLayout title="笔记 | Pixel Base" description="笔记列表与搜索" currentPath="/notes/">
  <header class="list-header">
    <h1 class="pixel-text">笔记列表</h1>
    <p>共 {notes.length} 篇，按时间倒序。支持关键词搜索和 tag 筛选。</p>
  </header>

  <section class="panel">
    <div class="search-controls">
      <input id="note-search-input" type="text" placeholder="搜索笔记标题、摘要、标签..." />
      <select id="note-tag-select">
        <option value="">全部标签</option>
        {tagSet.map((tag) => <option value={tag}>{tag}</option>)}
      </select>
      <a class="clear-link" href={`${import.meta.env.BASE_URL}notes/`}>清空</a>
    </div>

    <ul class="item-list">
      {
        notes.map((note: NoteEntry) => (
          <li
            class="item-card note-item"
            data-search={`${note.data.title} ${note.data.description} ${note.data.tags.join(" ")}`.toLowerCase()}
            data-tags={note.data.tags.join(",")}
          >
            <h3><a href={`${import.meta.env.BASE_URL}notes/${note.id}/`}>{note.data.title}</a></h3>
            <div class="meta-row">
              <span>{fmtDate(note.data.date)}</span>
              {
                note.data.tags.map((tag: string) => (
                  <a class="tag" href={`${import.meta.env.BASE_URL}notes/?tag=${encodeURIComponent(tag)}`}>#{tag}</a>
                ))
              }
            </div>
            <p>{note.data.description}</p>
          </li>
        ))
      }
    </ul>
  </section>

  <script>
    const input = document.getElementById("note-search-input");
    const tagSelect = document.getElementById("note-tag-select");
    const items = Array.from(document.querySelectorAll(".note-item"));
    const url = new URL(window.location.href);
    const initQ = url.searchParams.get("q") ?? "";
    const initTag = url.searchParams.get("tag") ?? "";
    if (input) input.value = initQ;
    if (tagSelect && initTag) tagSelect.value = initTag;

    const filterList = () => {
      const q = input?.value.trim().toLowerCase() ?? "";
      const tag = tagSelect?.value ?? "";
      items.forEach((item) => {
        const search = item.getAttribute("data-search") ?? "";
        const tags = (item.getAttribute("data-tags") ?? "").split(",").filter(Boolean);
        item.style.display = (!q || search.includes(q)) && (!tag || tags.includes(tag)) ? "" : "none";
      });
    };
    input?.addEventListener("input", filterList);
    tagSelect?.addEventListener("change", filterList);
    filterList();
  </script>
</BaseLayout>
