---
import { getCollection, type CollectionEntry } from "astro:content";
import MarkdownLayout from "../../layouts/MarkdownLayout.astro";

type ProjectEntry = CollectionEntry<"projects">;

const toDate = (value: unknown): Date => {
  if (value instanceof Date) return value;
  if (!value) return new Date(0);
  const date = new Date(value as string);
  return Number.isNaN(date.getTime()) ? new Date(0) : date;
};

export async function getStaticPaths() {
  const entries: ProjectEntry[] = await getCollection(
    "projects",
    (entry: ProjectEntry) => !entry.data.draft
  );
  return entries.map((entry: ProjectEntry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: ProjectEntry };
const { Content } = await entry.render();

const links = entry.data.links ?? {};
---

<MarkdownLayout
  title={entry.data.title}
  description={entry.data.description}
  dateText={entry.data.date ? toDate(entry.data.date).toISOString().slice(0, 10) : ""}
  tags={entry.data.tags}
  currentPath="/projects/"
>
  {(links.demo || links.github || links.store) && (
    <div class="post-meta">
      {links.demo && <a href={links.demo} target="_blank" rel="noreferrer">Demo</a>}
      {links.github && <a href={links.github} target="_blank" rel="noreferrer">GitHub</a>}
      {links.store && <a href={links.store} target="_blank" rel="noreferrer">Store</a>}
    </div>
  )}
  <Content />
</MarkdownLayout>
