---
import { getCollection, render, type CollectionEntry } from "astro:content";
import ContentLayout from "../../layouts/ContentLayout.astro";

type ProjectEntry = CollectionEntry<"projects">;

const toDate = (value: unknown): Date => {
  if (value instanceof Date) return value;
  if (!value) return new Date(0);
  const date = new Date(value as string);
  return Number.isNaN(date.getTime()) ? new Date(0) : date;
};

export async function getStaticPaths() {
  const posts: ProjectEntry[] = await getCollection("projects", (entry: ProjectEntry) => !entry.data.draft);
  return posts.map((entry: ProjectEntry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: ProjectEntry };
const { Content } = await render(entry);
const links = entry.data.links ?? {};
---

<ContentLayout
  title={entry.data.title}
  description={entry.data.description}
  dateText={entry.data.date ? toDate(entry.data.date).toISOString().slice(0, 10) : ""}
  tags={entry.data.tags}
  currentPath="/projects/"
  tagBasePath="projects"
  cover={entry.data.cover}
>
  {(links.demo || links.github || links.store) && (
    <div class="meta-row" style="margin-bottom: 12px;">
      {links.demo && <a class="tag" href={links.demo} target="_blank" rel="noreferrer">Demo</a>}
      {links.github && <a class="tag" href={links.github} target="_blank" rel="noreferrer">GitHub</a>}
      {links.store && <a class="tag" href={links.store} target="_blank" rel="noreferrer">Store</a>}
    </div>
  )}
  <Content />
</ContentLayout>
