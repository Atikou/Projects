---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

type BlogEntry = CollectionEntry<"blog">;
type NoteEntry = CollectionEntry<"notes">;
type ProjectEntry = CollectionEntry<"projects">;

const blogs: BlogEntry[] = await getCollection("blog", (entry: BlogEntry) => !entry.data.draft);
const notes: NoteEntry[] = await getCollection("notes", (entry: NoteEntry) => !entry.data.draft);
const projects: ProjectEntry[] = await getCollection("projects", (entry: ProjectEntry) => !entry.data.draft);

const toDate = (value: unknown): Date => {
  if (value instanceof Date) return value;
  const date = new Date(value as string);
  return Number.isNaN(date.getTime()) ? new Date(0) : date;
};

const latestBlogs = blogs
  .slice()
  .sort((a: BlogEntry, b: BlogEntry) => toDate(b.data.date).getTime() - toDate(a.data.date).getTime())
  .slice(0, 5);
---

<BaseLayout title="首页 | My Blog" description="一个基于 Astro 的博客站点" currentPath="/">
  <header class="page-header">
    <h1>欢迎来到我的博客</h1>
    <p>这里收录博客文章、开发笔记和项目记录，所有内容均来自现有 Markdown 文件。</p>
  </header>

  <section class="section-grid">
    <article class="section-panel">
      <h2>最新博客</h2>
      <p>最近发布的文章会优先显示在这里。</p>
      {latestBlogs.length === 0 ? (
        <p>暂无博客文章。</p>
      ) : (
        <ul class="post-list">
          {
            latestBlogs.map((post: BlogEntry) => (
              <li>
                <a class="post-card" href={`${import.meta.env.BASE_URL}blogs/${post.slug}/`}>
                  <h3>{post.data.title}</h3>
                  <div class="post-meta">
                    <span>{toDate(post.data.date).toISOString().slice(0, 10)}</span>
                    {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
                  </div>
                  {post.data.description && <p class="post-excerpt">{post.data.description}</p>}
                </a>
              </li>
            ))
          }
        </ul>
      )}
      <p><a href={`${import.meta.env.BASE_URL}blogs/`}>查看全部博客</a></p>
    </article>

    <article class="section-panel">
      <h2>内容概览</h2>
      <p>当前站点内容统计如下：</p>
      <ul>
        <li>博客：{blogs.length} 篇</li>
        <li>笔记：{notes.length} 篇</li>
        <li>项目：{projects.length} 篇</li>
      </ul>
      <p>
        <a href={`${import.meta.env.BASE_URL}notes/`}>浏览笔记</a> ·
        {" "}
        <a href={`${import.meta.env.BASE_URL}projects/`}>浏览项目</a>
      </p>
    </article>
  </section>
</BaseLayout>
