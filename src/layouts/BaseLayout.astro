---
import "../styles/site.css";

type NavItem = {
  href: string;
  label: string;
};

type Props = {
  title?: string;
  description?: string;
  currentPath?: string;
  backgroundCover?: string;
};

const {
  title = "Polyg",
  description = "Pixel style Astro site",
  currentPath = "/",
  backgroundCover = "",
} = Astro.props as Props;

const siteTitle = "Polyg";
const siteEmail = "formcyy@outlook.com";

const navItems: NavItem[] = [
  { href: "/", label: "首页" },
  { href: "/blogs/", label: "博客" },
  { href: "/notes/", label: "笔记" },
  { href: "/projects/", label: "项目" },
];

const makeUrl = (path: string) => `${import.meta.env.BASE_URL}${path.replace(/^\//, "")}`;
const resolvedBackgroundCover = backgroundCover
  ? /^https?:\/\//.test(backgroundCover)
    ? backgroundCover
    : makeUrl(`/${backgroundCover.replace(/^\//, "")}`)
  : "";
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={makeUrl("/favicon.svg")} />
  </head>
  <body
    class={resolvedBackgroundCover ? "page-with-cover" : ""}
    style={resolvedBackgroundCover ? `--page-cover-url: url('${resolvedBackgroundCover}');` : undefined}
  >
    <header class="site-header">
      <div class="container header-inner">
        <a class="site-title pixel-text" href={makeUrl("/")}>{siteTitle}</a>
        <nav class="site-nav" aria-label="主导航">
          {
            navItems.map((item) => (
              <a
                href={makeUrl(item.href)}
                class={currentPath.startsWith(item.href) && item.href !== "/"
                  ? "active"
                  : item.href === "/" && currentPath === "/"
                    ? "active"
                    : ""}
              >
                {item.label}
              </a>
            ))
          }
        </nav>
      </div>
    </header>

    <main class="container page-content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <span>© 2026 My Blog</span>
        <span>Powered by Astro</span>
        <a href={`mailto:${siteEmail}`}>{siteEmail}</a>
      </div>
    </footer>
  </body>
</html>
